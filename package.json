{
  "name": "orbitquest",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @orbitquest/web",
    "dev:api": "npm run dev --workspace @orbitquest/api",
    "build": "npm run build --workspaces --if-present && node scripts/build-precache.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "smoke": "node scripts/smoke.mjs",
    "art": "node scripts/optimize-art.mjs",
    "validate:content": "node --experimental-strip-types scripts/validate-content.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "sharp": "^0.35.3"
  }
}
